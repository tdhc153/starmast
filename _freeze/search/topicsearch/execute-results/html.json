alculus\",\"unit\":\"Trigonometric and Polar Functions\",\"link\":\"./studyguides/trigonometry-degrees.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Precalculus\",\"unit\":\"Trigonometric and Polar Functions\",\"link\":\"./studyguides/trigonometry-radians.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Precalculus\",\"unit\":\"Trigonometric and Polar Functions\",\"link\":\"./studyguides/trigonometricidentities-degrees.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Precalculus\",\"unit\":\"Trigonometric and Polar Functions\",\"link\":\"./studyguides/trigonometricidentities-radians.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Precalculus\",\"unit\":\"Functions Involving Parameters, vectors, and matrices\",\"link\":\"./studyguides/introductiontovectors.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Precalculus\",\"unit\":\"Functions Involving Parameters, vectors, and matrices\",\"link\":\"./studyguides/addandsm.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Calculus AB\",\"unit\":\"Differentiation: Definition and Fundamental Properties\",\"link\":\"./studyguides/introtodifferentiation.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Calculus AB\",\"unit\":\"Differentiation: Definition and Fundamental Properties\",\"link\":\"./studyguides/productrule.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Calculus AB\",\"unit\":\"Differentiation: Definition and Fundamental Properties\",\"link\":\"./studyguides/quotientrule.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Calculus AB\",\"unit\":\"Differentiation: Composite, Implicit, and Inverse Functions\",\"link\":\"./studyguides/chainrule.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Calculus AB\",\"unit\":\"Integration and Accumulation of Change\",\"link\":\"./studyguides/introtointegration.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Calculus AB\",\"unit\":\"Integration and Accumulation of Change\",\"link\":\"./studyguides/introtointegration.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Statistics\",\"unit\":\"Probability, random variables, and probability distributions\",\"link\":\"./studyguides/introtoprobability.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Statistics\",\"unit\":\"Probability, random variables, and probability distributions\",\"link\":\"./studyguides/conditionalprobability.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Statistics\",\"unit\":\"Probability, random variables, and probability distributions\",\"link\":\"./studyguides/expectedvariance.qmd\"},{\"country\":\"USA\",\"board\":\"AP\",\"course\":\"AP Statistics\",\"unit\":\"Inference for Categorical Data: proportions\",\"link\":\"./studyguides/hypothesistesting.qmd\"}] ;\n\nconst container       = document.getElementById(\"country-container\");\nconst boardTitle      = document.getElementById(\"board-title\");\nconst boardContainer  = document.getElementById(\"board-container\");\nconst courseTitle     = document.getElementById(\"course-title\");\nconst courseContainer = document.getElementById(\"course-container\");\nconst unitTitle       = document.getElementById(\"unit-title\");\nconst unitContainer   = document.getElementById(\"unit-container\");\nconst guideTitle      = document.getElementById(\"guide-title\");\nconst guideContainer  = document.getElementById(\"guide-container\");\n\nlet selectedCountry = null;\nlet selectedBoard   = null;\nlet selectedCourse  = null;\nlet selectedUnit    = null;\n\n// COUNTRY SELECTION BOXES\ncountries.forEach(country => {\n  const box = document.createElement(\"div\");\n  box.className = \"country-box\";\n  box.textContent = country;\n\n  box.onclick = () => {\n    selectedCountry = country;\n    selectedBoard = null;\n    selectedCourse = null;\n    selectedUnit   = null;\n\n    container.querySelectorAll(\".country-box\").forEach(b =>\n      b.classList.remove(\"selected\")\n    );\n    box.classList.add(\"selected\");\n\n    boardContainer.innerHTML = \"\";\n    courseContainer.innerHTML = \"\";\n    unitContainer.innerHTML = \"\";\n    guideContainer.innerHTML = \"\";\n    courseTitle.style.display = \"none\";\n    unitTitle.style.display = \"none\";\n    guideTitle.style.display = \"none\";\n\n    updateBoards();\n  };\n\n  container.appendChild(box);\n});\n\n// EXAM BOARD SELECTION BOXES\nfunction updateBoards() {\n  boardContainer.innerHTML = \"\";\n\n  if (!selectedCountry) {\n    boardTitle.style.display = \"none\";\n    return;\n  }\n\n  boardTitle.style.display = \"block\";\n\n  const boardsForCountry = Array.from(new Set(\n    navData\n      .filter(row => row.country === selectedCountry)\n      .map(row => row.board)\n  )).sort();\n\n  boardsForCountry.forEach(board => {\n    const box = document.createElement(\"div\");\n    box.className = \"board-box\";\n    box.textContent = board;\n\n    box.onclick = () => {\n      selectedBoard = board;\n      selectedCourse = null;\n      selectedUnit   = null;\n\n      boardContainer.querySelectorAll(\".board-box\").forEach(b =>\n        b.classList.remove(\"selected\")\n      );\n      box.classList.add(\"selected\");\n\n      courseContainer.innerHTML = \"\";\n      unitContainer.innerHTML = \"\";\n      guideContainer.innerHTML = \"\";\n      unitTitle.style.display = \"none\";\n      guideTitle.style.display = \"none\";\n\n      updateCourses();\n    };\n\n    boardContainer.appendChild(box);\n  });\n}\n\n// COURSE SELECTION BOXES\nfunction updateCourses() {\n  if (!selectedCountry || !selectedBoard) {\n    courseTitle.style.display = \"none\";\n    return;\n  }\n\n  courseTitle.style.display = \"block\";\n  courseContainer.innerHTML = \"\";\n\n  const coursesForSelection = Array.from(new Set(\n    navData\n      .filter(row =>\n        row.country === selectedCountry &&\n        row.board === selectedBoard\n      )\n      .map(row => row.course)\n  )).sort();\n\n  coursesForSelection.forEach(course => {\n    const box = document.createElement(\"div\");\n    box.className = \"course-box\";\n    box.textContent = course;\n\n    box.onclick = () => {\n      selectedCourse = course;\n      selectedUnit   = null;\n\n      courseContainer.querySelectorAll(\".course-box\").forEach(b =>\n        b.classList.remove(\"selected\")\n      );\n      box.classList.add(\"selected\");\n\n      unitContainer.innerHTML = \"\";\n      guideContainer.innerHTML = \"\";\n      guideTitle.style.display = \"none\";\n\n      updateUnits();\n    };\n\n    courseContainer.appendChild(box);\n  });\n}\n\n// UNIT (TOPIC) SELECTION BOXES\nfunction updateUnits() {\n  if (!selectedCountry || !selectedBoard || !selectedCourse) {\n    unitTitle.style.display = \"none\";\n    return;\n  }\n\n  unitTitle.style.display = \"block\";\n  unitContainer.innerHTML = \"\";\n\n  const unitsForSelection = Array.from(new Set(\n    navData\n      .filter(row =>\n        row.country === selectedCountry &&\n        row.board === selectedBoard &&\n        row.course === selectedCourse\n      )\n      .map(row => row.unit)\n  )).sort();\n\n  unitsForSelection.forEach(unit => {\n    const box = document.createElement(\"div\");\n    box.className = \"unit-box\";\n    box.textContent = unit;\n\n    box.onclick = () => {\n      selectedUnit = unit;\n\n      unitContainer.querySelectorAll(\".unit-box\").forEach(b =>\n        b.classList.remove(\"selected\")\n      );\n      box.classList.add(\"selected\");\n\n      updateGuides();\n    };\n\n    unitContainer.appendChild(box);\n  });\n}\n\n\n// GUIDE LISTING SELECTION\nfunction updateGuides() {\n  guideContainer.innerHTML = \"\";\n\n  if (!selectedUnit) {\n    guideTitle.style.display = \"none\";\n    return;\n  }\n\n  guideTitle.style.display = \"block\";\n\n  const guidesForSelection = navData.filter(row =>\n    row.country === selectedCountry &&\n    row.board === selectedBoard &&\n    row.course === selectedCourse &&\n    row.unit === selectedUnit\n  );\n\n  guidesForSelection.forEach(guide => {\n    const card = document.createElement(\"a\");\n    card.className = \"guide-card\";\n\n    // Convert ./studyguides/file.qmd → /studyguides/file.html\n    let href = guide.link || \"\";\n\n    if (href.startsWith(\"./\")) {\n      href = href.substring(2);\n    }\n\n    if (href.endsWith(\".qmd\")) {\n      href = href.slice(0, -4) + \".html\";\n    }\n\n    if (!href.startsWith(\"/\")) {\n      href = \"/\" + href;\n    }\n\n    card.href = href;\n    card.target = \"_self\";\n\n    card.textContent = guide.title || guide.unit;\n\n    guideContainer.appendChild(card);\n  });\n}\n\n</script>\n\n<style>\n.country-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));\n  gap: 14px;\n  margin-top: 1rem;\n}\n\n.country-box,\n.board-box,\n.course-box,\n.unit-box,\n.guide-card {\n  padding: 16px;\n  border: 2px solid #ccc;\n  border-radius: 12px;\n  text-align: center;\n  cursor: pointer;\n  font-weight: 600;\n  transition: 0.2s;\n  background-color: #f8f8f8;\n  text-decoration: none;\n  color: black;\n}\n\n.country-box:hover,\n.board-box:hover,\n.course-box:hover,\n.unit-box:hover,\n.guide-card:hover {\n  border-color: #000;\n  background-color: #eee;\n}\n\n.country-box.selected {\n  border-color: #2563eb;\n  background-color: #dbeafe;\n}\n\n.board-box.selected {\n  border-color: #16a34a;\n  background-color: #dcfce7;\n}\n\n.course-box.selected {\n  border-color: #2563eb;\n  background-color: #dbeafe;\n}\n\n.unit-box.selected {\n  border-color: #16a34a;\n  background-color: #dcfce7;\n}\n</style>",
